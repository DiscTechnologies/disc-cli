# Disc CLI dev script environment config
# Copy to .env.local or .env.prod and fill in values.
# Usage: ./disc.sh --env local <command>
#        ./disc.sh --env prod  <command>
#        ./disc.sh <command>          # defaults to --env local

# HTTP base URL for the Disc API
DISC_HTTP_BASE_URL=http://localhost:3001

# WebSocket URL for Disc signal streams
DISC_WS_URL=ws://localhost:8097

# Client ID tag attached to connections (helps identify traffic source in logs)
DISC_CLIENT_ID=disc-cli-local

# API key — leave empty to fall back to the key stored by `disc auth api-key set`
DISC_API_KEY=
